# --------------------------------------------------------------------------------
# PRODUCTION environment template. On the VM:
#   cp .env.production.example .env
# then fill in every value marked CHANGE_ME. NEVER commit the real .env.
# --------------------------------------------------------------------------------

# ---- Core ----------------------------------------------------------------------
DEBUG=False
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=CHANGE_ME
# Comma-separated. Your domain + the VM's external IP.
ALLOWED_HOSTS=api.example.com
# Comma-separated origins that call the API (your web/mobile frontends).
CORS_ALLOWED_ORIGINS=https://app.example.com

# ---- Database (Postgres runs in the `db` container) ----------------------------
POSTGRES_DB=sabil
POSTGRES_USER=sabil
POSTGRES_PASSWORD=CHANGE_ME_strong_password
# Host is the compose service name `db`, not localhost.
DATABASE_URL=postgres://sabil:CHANGE_ME_strong_password@db:5432/sabil

# ---- Redis / Celery (Redis runs in the `redis` container) ----------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# ---- Gunicorn tuning (optional) ------------------------------------------------
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60

# ---- Media storage: Google Cloud Storage via S3 interoperability ---------------
# Create a bucket + HMAC key (see docs/DEPLOYMENT_GCP.md). This keeps uploaded
# files off the VM disk so they survive rebuilds.
USE_MINIO=True
AWS_ACCESS_KEY_ID=CHANGE_ME_gcs_hmac_access_id
AWS_SECRET_ACCESS_KEY=CHANGE_ME_gcs_hmac_secret
AWS_STORAGE_BUCKET_NAME=sabil-life-media-prod
AWS_S3_ENDPOINT_URL=https://storage.googleapis.com
AWS_S3_REGION_NAME=me-central1
AWS_S3_ADDRESSING_STYLE=path
AWS_QUERYSTRING_AUTH=False

# ---- Email ---------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_USE_TLS=True
EMAIL_PORT=587
EMAIL_HOST_USER=CHANGE_ME
EMAIL_HOST_PASSWORD=CHANGE_ME

# ---- Error tracking ------------------------------------------------------------
SENTRY_DSN=

# ---- Push notifications (Firebase) ---------------------------------------------
# Put the service-account JSON at ./secrets/sabil-life-firebase-adminsdk.json on
# the VM; it is mounted read-only into the containers at /app/secrets/.
PUSH_NOTIFICATIONS_ENABLED=True
FIREBASE_CREDENTIALS=/app/secrets/sabil-life-firebase-adminsdk.json

# ---- Billing gate --------------------------------------------------------------
BILLING_GATE_ENABLED=False
